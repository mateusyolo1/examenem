{
  "version": 1,
  "sdk_version": "0.20.1",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://jwkavjxsddpvnclpflsd.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "exame-enem-mcp",
      "version": "0.1.0",
      "title": "Exame ENEM"
    },
    "tools": [
      {
        "name": "get_today_agenda",
        "title": "Get today's study agenda",
        "description": "Returns today's ENEM study tasks (videos, questions, flashcards, essays, mock exams) from the signed-in student's plan, grouped by type.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "date": {
              "description": "ISO date (YYYY-MM-DD). Defaults to today.",
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_study_plan",
        "title": "Get the full study plan",
        "description": "Returns the student's complete ENEM study plan: all scheduled tasks, config, and progress counts. Optionally filter to a date range.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "fromDate": {
              "description": "Inclusive lower bound (YYYY-MM-DD).",
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "toDate": {
              "description": "Inclusive upper bound (YYYY-MM-DD).",
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 500
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "mark_task_done",
        "title": "Mark a study task done",
        "description": "Marks a study task (or all tasks matching a topic slug on a date) as completed in the student's plan. Provide either taskId or topicSlug.",
        "annotations": {
          "readOnlyHint": false,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "taskId": {
              "description": "Exact task id from get_today_agenda.",
              "type": "string"
            },
            "topicSlug": {
              "description": "Topic slug to match instead.",
              "type": "string"
            },
            "date": {
              "description": "Restrict topicSlug matches to this date.",
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "toggle": {
              "description": "If true, toggle completion instead of forcing done.",
              "type": "boolean"
            }
          }
        },
        "outputSchema": null
      }
    ]
  }
}
